local VALIDATE_URL   = "https://looprix-validate.slivkineepy.workers.dev"
local SOURCE_URL     = "https://looprix-source.slivkineepy.workers.dev"
local SCRIPT_ID      = "e8dbb2b4-4a7c-421d-9a4c-0904bc361979"
local MAX_RETRIES    = 2
local RETRY_DELAY    = 1

local HttpService  = game:GetService("HttpService")
local Players      = game:GetService("Players")
local LocalPlayer  = Players.LocalPlayer

local key = getgenv and getgenv().script_key

if not key or type(key) ~= "string" or key == "" or key == "YOUR_KEY_HERE" then
    pcall(function() LocalPlayer:Kick("❌ No key provided. Set getgenv().script_key first.") end)
    return
end

local function getHWID()
    local parts = {}
    if identifyexecutor then
        table.insert(parts, tostring(identifyexecutor()))
    elseif syn and syn.get_hwid then
        local ok, id = pcall(syn.get_hwid)
        if ok and id then table.insert(parts, tostring(id)) end
    end
    table.insert(parts, tostring(game.PlaceId))
    table.insert(parts, tostring(LocalPlayer.UserId))
    return table.concat(parts, "_")
end

local function httpPost(url, bodyStr)
    -- Try 1: HttpService:RequestAsync
    local ok, res = pcall(function()
        return HttpService:RequestAsync({
            Url = url, Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = bodyStr
        })
    end)
    if ok and res and res.Success and res.Body and res.Body ~= "" then return res.Body end

    -- Try 2: syn.request
    if syn and syn.request then
        local ok2, res2 = pcall(function()
            return syn.request({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = bodyStr })
        end)
        if ok2 and res2 and res2.Body and res2.Body ~= "" then return res2.Body end
    end

    -- Try 3: request()
    if request and type(request) == "function" then
        local ok3, res3 = pcall(function()
            return request({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = bodyStr })
        end)
        if ok3 and res3 and res3.Body and res3.Body ~= "" then return res3.Body end
    end

    -- Try 4: http_request()
    if http_request and type(http_request) == "function" then
        local ok4, res4 = pcall(function()
            return http_request({ url = url, method = "POST", headers = { ["Content-Type"] = "application/json" }, body = bodyStr })
        end)
        if ok4 and res4 and res4.body and res4.body ~= "" then return res4.body end
    end

    -- Try 5: HttpService:PostAsync
    local ok5, res5 = pcall(function()
        return HttpService:PostAsync(url, bodyStr, Enum.HttpContentType.ApplicationJson)
    end)
    if ok5 and res5 and res5 ~= "" then return res5 end

    return nil
end

local isValid    = false
local failReason = "Key validation failed"

local displayName = nil
local ok, dn = pcall(function() return LocalPlayer.DisplayName end)
if ok and dn then displayName = dn end

for attempt = 1, MAX_RETRIES + 1 do
    local ok, result, reason = pcall(function()
        local payload = HttpService:JSONEncode({
            key         = key,
            hwid        = getHWID(),
            userId      = LocalPlayer.UserId,
            username    = LocalPlayer.Name,
            displayName = displayName,
            scriptId    = SCRIPT_ID,
            placeId     = game.PlaceId,
        })

        local startTime = tick()
        local raw = httpPost(VALIDATE_URL, payload)

        if (tick() - startTime) > 10 then return false, "Validation timeout" end
        if not raw or raw == "" then return false, "No response from server" end

        local decOk, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not decOk or type(data) ~= "table" then return false, "Invalid response format" end
        if data.valid ~= true then return false, data.reason or "Key denied" end

        return true, "OK"
    end)

    if ok and result == true then
        isValid = true
        break
    else
        if not ok then
            failReason = (type(result) == "string" and result) or "Validation error"
        else
            failReason = (type(reason) == "string" and reason ~= "" and reason)
                      or (type(result) == "string" and result ~= "" and result)
                      or "Key validation failed"
        end
        if attempt <= MAX_RETRIES then task.wait(RETRY_DELAY) end
    end
end

if not isValid then
    pcall(function() LocalPlayer:Kick("❌ " .. failReason) end)
    return
end

print("[Looprix] Authorized ✓")

local scriptUrl = SOURCE_URL .. "?key=" .. key .. "&id=" .. SCRIPT_ID
local actualScript = nil

local loadOk = pcall(function()
    actualScript = game:HttpGet(scriptUrl)
end)

if not loadOk or not actualScript or actualScript == "" or actualScript:sub(1,2) == "--" then
    pcall(function() LocalPlayer:Kick("❌ Failed to load script") end)
    return
end

loadstring(actualScript)()

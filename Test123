local function httpPost(url, body)
    local methods = {
        function()
            return HttpService:RequestAsync({ Url=url, Method="POST", Headers={["Content-Type"]="application/json"}, Body=body })
        end,
        function()
            if not (syn and syn.request) then return nil end
            return syn.request({ Url=url, Method="POST", Headers={["Content-Type"]="application/json"}, Body=body })
        end,
        function()
            if not (request and type(request)=="function") then return nil end
            return request({ Url=url, Method="POST", Headers={["Content-Type"]="application/json"}, Body=body })
        end,
        function()
            if not (http_request and type(http_request)=="function") then return nil end
            local r = http_request({ url=url, method="POST", headers={["Content-Type"]="application/json"}, body=body })
            return r and { Body = r.body } or nil
        end,
    }
    for _, fn in ipairs(methods) do
        local ok, res = pcall(fn)
        if ok and res and (res.Body or res.body) and (res.Body or res.body) ~= "" then
            return res.Body or res.body
        end
    end
    return nil
end

